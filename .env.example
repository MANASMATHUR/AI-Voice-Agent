# ===========================================
# AI Voice Agent – Environment
# ===========================================
#
# REQUIRED: Only OPENAI_API_KEY is needed to run the prototype.
# Voice output uses your browser's built-in speech when ElevenLabs is not set.
#
# ===========================================

# --- OpenAI (LLM) - REQUIRED ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- ElevenLabs (optional - nicer voice; if not set, browser TTS is used) ---
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# ELEVENLABS_VOICE_ID=rachel

# --- PlayHT (optional - alternative TTS) ---
# PLAYHT_USER_ID=your-playht-user-id
# PLAYHT_API_KEY=your-playht-api-key

# --- Twilio (optional - for real phone calls) ---
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# --- VAPI (optional) ---
# VAPI_API_KEY=your-vapi-api-key

# --- Apollo (optional - CRM) ---
# APOLLO_API_KEY=your-apollo-api-key

# --- App Config ---
APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# --- Optional: Language preference for agent ---
AGENT_PRIMARY_LANGUAGE=hi
# hi = Hindi, en = English, both = greet in either
