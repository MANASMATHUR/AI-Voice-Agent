# ===========================================
# AI Voice Agent – Environment Configuration
# Riverwood Estate Customer Voice Agent
# ===========================================

# ============== REQUIRED ==============

# OpenAI API Key (for LLM + fallback TTS)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============== RECOMMENDED ==============

# Upstash Redis (for conversation memory + caching)
# Free tier: 10,000 requests/day
# Get credentials: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ElevenLabs (for realistic voice - HIGHLY RECOMMENDED)
# Much more natural than browser TTS
# Get API key: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
# Voice IDs: pFZP5JQG7iQjIQuC4Bku (Lily), Xb7hH8MSUJpSbSDYk0k2 (Alice multilingual)

# ============== FOR PHONE CALLS ==============

# Twilio (for real phone call capability)
# Get credentials: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============== OPTIONAL ==============

# PlayHT (alternative TTS provider)
# PLAYHT_USER_ID=your-playht-user-id
# PLAYHT_API_KEY=your-playht-api-key

# App Configuration
APP_ENV=development
AGENT_PRIMARY_LANGUAGE=en

# ============== NOTES ==============
# 
# Minimum for web demo: OPENAI_API_KEY only
# Recommended for demo: + ELEVENLABS_API_KEY + UPSTASH_REDIS
# Full production: + TWILIO credentials
#
# You can request paid API keys from Riverwood:
# Email: sanyam@riverwoodindia.com
# ===================================
