# ElevenLabs (premium voice synthesis)
# Get key: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
ELEVENLABS_VOICE_ID_HI=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_VOICE_ID_MR=Xb7hH8MSUJpSbSDYk0k2

# Upstash Redis (conversation memory)
# Get credentials: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# VAPI (real-time voice AI orchestration)
# Get keys: https://dashboard.vapi.ai/
VAPI_API_KEY=your-vapi-private-api-key
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_SERVER_SECRET=your-webhook-signing-secret
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id

# Twilio (legacy phone call fallback)
# Get credentials: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

APP_ENV=development
AGENT_PRIMARY_LANGUAGE=en
