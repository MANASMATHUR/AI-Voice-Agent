# =============================================================================
# Riverwood AI Voice Agent — PRODUCTION STACK (mandatory defaults)
# =============================================================================
# Text Chat (agent.html): OPENAI + ELEVENLABS (ElevenLabs is required unless you set ELEVENLABS_OPTIONAL=true for local dev only).
# Voice Call (agent-vapi.html): VAPI_PUBLIC_KEY + assistant configured in VAPI with ElevenLabs voice + OpenAI model.
# =============================================================================

# --- OpenAI (LLM) — REQUIRED ---
OPENAI_API_KEY=sk-or-sk-proj-your-key

# --- ElevenLabs (premium TTS for Text Chat API) — REQUIRED in production ---
# Get key: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
ELEVENLABS_VOICE_ID_HI=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_VOICE_ID_MR=Xb7hH8MSUJpSbSDYk0k2

# Local dev only: allow OpenAI TTS fallback if ElevenLabs is not set
# ELEVENLABS_OPTIONAL=true

# --- VAPI (Voice Call page) — REQUIRED for agent-vapi.html ---
# Dashboard: https://dashboard.vapi.ai/ — create assistant with ElevenLabs + OpenAI
VAPI_PUBLIC_KEY=your-vapi-public-key
# UUID from VAPI → Assistants → open your assistant (e.g. Riverwood Assistant)
VAPI_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VAPI_API_KEY=your-private-key  # optional: webhooks / server tools

# --- Redis (recommended for evaluation: memory + scalability) ---
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Optional: Twilio, etc. ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

APP_ENV=development
AGENT_PRIMARY_LANGUAGE=en
